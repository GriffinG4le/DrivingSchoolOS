## Frontend (Vite) Supabase client (public)
# Supabase project URL looks like: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the "anon public" key from Supabase project settings
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

## Backend (server-to-DB) Postgres connection
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
PG_SSLMODE=require

## App secrets (server-only)
JWT_SECRET=change-me
PLATFORM_BOOTSTRAP_KEY=
PAYBILL_NUMBER=YOUR_PAYBILL

## Daraja (M-Pesa) C2B (server-only)
# sandbox | live
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
# Your paybill/shortcode (often same as PAYBILL_NUMBER)
DARAJA_SHORTCODE=YOUR_PAYBILL
# Optional: Completed or Cancelled
DARAJA_RESPONSE_TYPE=Completed
# Publicly reachable endpoints pointing to this API server
DARAJA_VALIDATION_URL=https://YOUR_DOMAIN/mpesa/c2b/validation
DARAJA_CONFIRMATION_URL=https://YOUR_DOMAIN/mpesa/c2b/confirmation
